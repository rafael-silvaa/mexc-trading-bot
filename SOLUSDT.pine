//@version=5
strategy("MEXC Breakout Bot - SOLUSDT v3.0", overlay=true, calc_on_every_tick=false, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=5, commission_type=strategy.commission.percent, commission_value=0.05)

// === INPUTS ===
lookback = input.int(20, title="Períodos de Rompimento (Donchian)")
vol_length = input.int(20, title="Períodos Média de Volume")
sl_mult = input.float(2.0, title="Multiplicador do Stop Loss (ATR)", step=0.1)
rr_ratio = input.float(2.0, title="Risco/Retorno (Take Profit)", step=0.1)

// === INDICADORES ===
ema200 = ta.ema(close, 200)
atr = ta.atr(14)
vol_ma = ta.sma(volume, vol_length)

// Canais de Donchian (Calcula a Máxima e Mínima dos últimos X períodos)
// Usamos [1] para olhar para o passado e não incluir a vela que está a formar
highest_high = ta.highest(high[1], lookback) 
lowest_low = ta.lowest(low[1], lookback)

plot(highest_high, color=color.green, title="Resistência", style=plot.style_stepline)
plot(lowest_low, color=color.red, title="Suporte", style=plot.style_stepline)
plot(ema200, color=color.white, title="EMA 200", linewidth=2)

// === LÓGICA BOOLEANA (BREAKOUT) ===
// Confirmação de anomalia de volume
vol_spike = volume > vol_ma

// LONG: Acima da EMA200, preço fecha ACIMA da resistência, COM volume extra.
longCond = (close > ema200) and (close > highest_high) and vol_spike

// SHORT: Abaixo da EMA200, preço fecha ABAIXO do suporte, COM volume extra.
shortCond = (close < ema200) and (close < lowest_low) and vol_spike

// === VARIÁVEIS DE ESTADO ===
var float sl = na
var float tp = na

// === MOTOR DE EXECUÇÃO ===
if (longCond and strategy.position_size == 0)
    sl := close - (atr * sl_mult)
    tp := close + ((close - sl) * rr_ratio) 
    
    json_payload = '{"action": "LONG", "ticker": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + '}'
    strategy.entry("Long", strategy.long, alert_message=json_payload)
    strategy.exit("Exit Long", "Long", stop=sl, limit=tp)

if (shortCond and strategy.position_size == 0)
    sl := close + (atr * sl_mult)
    tp := close - ((sl - close) * rr_ratio)
    
    json_payload = '{"action": "SHORT", "ticker": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + '}'
    strategy.entry("Short", strategy.short, alert_message=json_payload)
    strategy.exit("Exit Short", "Short", stop=sl, limit=tp)