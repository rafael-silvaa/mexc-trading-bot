//@version=5
strategy("MEXC Mean Reversion Bot - SOLUSDT v4.0", overlay=true, calc_on_every_tick=false, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=5, commission_type=strategy.commission.percent, commission_value=0.05)

// === INPUTS ===
bb_length = input.int(20, title="Períodos Bollinger Bands")
bb_mult = input.float(2.5, title="Multiplicador BB (Extremos)", step=0.1) 
rsi_len = input.int(14, title="Períodos RSI")
rsi_ob = input.int(75, title="RSI Sobrecompra (Euforia)")
rsi_os = input.int(25, title="RSI Sobrevenda (Pânico)")
sl_mult = input.float(1.5, title="Stop Loss (ATR)", step=0.1)
rr_ratio = input.float(1.2, title="Risco/Retorno", step=0.1) // Alvo mais curto para garantir a Win Rate

// === INDICADORES ===
[middle, upper, lower] = ta.bb(close, bb_length, bb_mult)
rsi = ta.rsi(close, rsi_len)
atr = ta.atr(14)

plot(middle, color=color.yellow, title="Média BB")
plot(upper, color=color.gray, title="Banda Superior")
plot(lower, color=color.gray, title="Banda Inferior")

// === LÓGICA BOOLEANA (MEAN REVERSION) ===
// LONG: Preço foi abaixo da banda inferior (Wick), fechou acima dela, e RSI está em pânico.
longCond = (low < lower) and (close > lower) and (rsi < rsi_os)

// SHORT: Preço foi acima da banda superior (Wick), fechou abaixo dela, e RSI está em euforia.
shortCond = (high > upper) and (close < upper) and (rsi > rsi_ob)

// === VARIÁVEIS DE ESTADO ===
var float sl = na
var float tp = na

// === MOTOR DE EXECUÇÃO ===
if (longCond and strategy.position_size == 0)
    sl := close - (atr * sl_mult)
    tp := close + ((close - sl) * rr_ratio) 
    
    json_payload = '{"action": "LONG", "ticker": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + '}'
    strategy.entry("Long", strategy.long, alert_message=json_payload)
    strategy.exit("Exit Long", "Long", stop=sl, limit=tp)

if (shortCond and strategy.position_size == 0)
    sl := close + (atr * sl_mult)
    tp := close - ((sl - close) * rr_ratio)
    
    json_payload = '{"action": "SHORT", "ticker": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + '}'
    strategy.entry("Short", strategy.short, alert_message=json_payload)
    strategy.exit("Exit Short", "Short", stop=sl, limit=tp)